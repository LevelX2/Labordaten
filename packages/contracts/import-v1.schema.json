{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labordaten.local/contracts/import-v1.schema.json",
  "title": "Labordaten Import V1",
  "type": "object",
  "required": ["schemaVersion", "quelleTyp", "befund", "messwerte"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "quelleTyp": {
      "type": "string",
      "enum": ["json", "ki_json", "csv", "excel", "manuell"]
    },
    "personHinweis": {
      "type": "string"
    },
    "befund": {
      "type": "object",
      "required": ["entnahmedatum"],
      "properties": {
        "personId": { "type": "string" },
        "laborId": { "type": "string" },
        "laborName": { "type": "string" },
        "entnahmedatum": { "type": "string", "format": "date" },
        "befunddatum": { "type": "string", "format": "date" },
        "bemerkung": { "type": "string" },
        "dokumentPfad": { "type": "string" }
      },
      "additionalProperties": false
    },
    "messwerte": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["originalParametername", "wertTyp", "wertRohText"],
        "properties": {
          "parameterId": { "type": "string" },
          "originalParametername": { "type": "string" },
          "wertTyp": {
            "type": "string",
            "enum": ["numerisch", "text"]
          },
          "wertOperator": {
            "type": "string",
            "enum": ["exakt", "kleiner_als", "kleiner_gleich", "groesser_als", "groesser_gleich", "ungefaehr"]
          },
          "wertRohText": { "type": "string" },
          "wertNum": { "type": "number" },
          "wertText": { "type": "string" },
          "einheitOriginal": { "type": "string" },
          "bemerkungKurz": { "type": "string" },
          "bemerkungLang": { "type": "string" },
          "kiHinweis": { "type": "string" },
          "referenzTextOriginal": { "type": "string" },
          "untereGrenzeNum": { "type": "number" },
          "untereGrenzeOperator": {
            "type": "string",
            "enum": ["groesser_als", "groesser_gleich", "kleiner_als", "kleiner_gleich"]
          },
          "obereGrenzeNum": { "type": "number" },
          "obereGrenzeOperator": {
            "type": "string",
            "enum": ["groesser_als", "groesser_gleich", "kleiner_als", "kleiner_gleich"]
          },
          "referenzEinheit": { "type": "string" },
          "referenzGeschlechtCode": { "type": "string" },
          "referenzAlterMinTage": { "type": "integer" },
          "referenzAlterMaxTage": { "type": "integer" },
          "referenzBemerkung": { "type": "string" },
          "aliasUebernehmen": { "type": "boolean" },
          "unsicherFlag": { "type": "boolean" },
          "pruefbedarfFlag": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "gruppenVorschlaege": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "messwertIndizes"],
        "properties": {
          "name": { "type": "string" },
          "beschreibung": { "type": "string" },
          "messwertIndizes": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          }
        },
        "additionalProperties": false
      }
    },
    "parameterVorschlaege": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["anzeigename", "messwertIndizes"],
        "properties": {
          "anzeigename": { "type": "string" },
          "wertTypStandard": {
            "type": "string",
            "enum": ["numerisch", "text"]
          },
          "standardEinheit": { "type": "string" },
          "primaereKlassifikation": {
            "type": "string",
            "enum": ["krankwert", "schluesselwert", "gesundmachwert"]
          },
          "beschreibungKurz": { "type": "string" },
          "moeglicheAliase": {
            "type": "array",
            "items": { "type": "string" }
          },
          "begruendungAusDokument": { "type": "string" },
          "unsicherFlag": { "type": "boolean" },
          "messwertIndizes": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
